import React, { useState, useEffect } from "react";

export default function App() {
  const [workouts, setWorkouts] = useState([]);
  const [meals, setMeals] = useState([]);
  const [workoutInput, setWorkoutInput] = useState("");
  const [mealInput, setMealInput] = useState("");

  // Load saved data from localStorage on first render
  useEffect(() => {
    const savedWorkouts = localStorage.getItem("workouts");
    const savedMeals = localStorage.getItem("meals");

    if (savedWorkouts) setWorkouts(JSON.parse(savedWorkouts));
    if (savedMeals) setMeals(JSON.parse(savedMeals));
  }, []);

  // Save data to localStorage whenever workouts or meals change
  useEffect(() => {
    localStorage.setItem("workouts", JSON.stringify(workouts));
    localStorage.setItem("meals", JSON.stringify(meals));
  }, [workouts, meals]);

  const addWorkout = () => {
    if (!workoutInput.trim()) return;
    setWorkouts([{ name: workoutInput, time: new Date() }, ...workouts]);
    setWorkoutInput("");
  };

  const addMeal = () => {
    if (!mealInput.trim()) return;
    setMeals([{ name: mealInput, time: new Date() }, ...meals]);
    setMealInput("");
  };

  const deleteWorkout = (index) => {
    setWorkouts(workouts.filter((_, i) => i !== index));
  };

  const deleteMeal = (index) => {
    setMeals(meals.filter((_, i) => i !== index));
  };

  return (
    <div style={{ padding: "20px", fontFamily: "Arial" }}>
      <h1>Fitness Tracker 💪</h1>

      <div style={{ display: "flex", gap: "40px", marginTop: "20px" }}>
        {/* Workouts */}
        <div>
          <h2>Workouts</h2>
          <input
            placeholder="Chest day, run..."
            value={workoutInput}
            onChange={(e) => setWorkoutInput(e.target.value)}
            onKeyDown={(e) => e.key === "Enter" && addWorkout()}
          />
          <button onClick={addWorkout}>Add</button>

          <ul>
            {workouts.map((w, i) => (
              <li key={i} style={{ marginBottom: "5px" }}>
                {w.name} ({new Date(w.time).toLocaleTimeString()})
                <button
                  style={{ marginLeft: "10px" }}
                  onClick={() => deleteWorkout(i)}
                >
                  ❌
                </button>
              </li>
            ))}
          </ul>
        </div>

        {/* Meals */}
        <div>
          <h2>Meals</h2>
          <input
            placeholder="Chicken, protein shake..."
            value={mealInput}
            onChange={(e) => setMealInput(e.target.value)}
            onKeyDown={(e) => e.key === "Enter" && addMeal()}
          />
          <button onClick={addMeal}>Add</button>

          <ul>
            {meals.map((m, i) => (
              <li key={i} style={{ marginBottom: "5px" }}>
                {m.name} ({new Date(m.time).toLocaleTimeString()})
                <button
                  style={{ marginLeft: "10px" }}
                  onClick={() => deleteMeal(i)}
                >
                  ❌
                </button>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  );
}
